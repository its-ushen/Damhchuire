<% content_for :title, "Quickstart — Damhchuire" %>

<div class="page-wrap" data-controller="copy-code">

  <div class="page-hdr">
    <p class="page-hdr-tag">01 / Quickstart</p>
    <h1 class="page-hdr-title">Up and running<br>in minutes.</h1>
    <p class="page-hdr-body">
      Add the crate, emit on-chain, handle the response — everything you need to trigger your first oracle action.
    </p>
  </div>

  <div class="qs-body">
    <div class="code-window">
      <div class="code-window-bar">
        <span class="code-dot code-dot-r"></span>
        <span class="code-dot code-dot-y"></span>
        <span class="code-dot code-dot-g"></span>
        <span class="code-window-title">quickstart.rs</span>
        <button
          class="code-copy-btn"
          data-copy-code-target="btn"
          data-action="click->copy-code#copy"
        >Copy</button>
      </div>

      <pre class="code-block qs-code-block" data-copy-code-target="code"><code><span class="c-comment"># ── 1. Add dependency ──────────────────────────────────────────</span>
<span class="c-comment"># Cargo.toml</span>
[dependencies]
damhchuire-sdk = <span class="c-string">{ path = "../da-sdk/rust" }</span>

<span class="c-comment"># ── 2. Emit on-chain ───────────────────────────────────────────</span>
<span class="c-keyword">use</span> damhchuire_sdk::{<span class="c-fn">call_weather_now_action_from</span>, <span class="c-fn">WeatherNowParams</span>};

<span class="c-keyword">let</span> request_id = <span class="c-fn">call_weather_now_action_from</span>(
    &<span class="c-keyword">mut</span> ctx.accounts.state,
    <span class="c-fn">WeatherNowParams</span> { city: <span class="c-string">"Dublin"</span>.to_string(), unit: <span class="c-fn">None</span> },
)?;
<span class="c-dim">// emits ActionRequested { request_id, action_slug, params_json }</span>

<span class="c-comment"># ── 3. Handle response ─────────────────────────────────────────</span>
<span class="c-keyword">use</span> damhchuire_sdk::<span class="c-fn">WeatherNowResponse</span>;

<span class="c-keyword">let</span> resp: <span class="c-fn">WeatherNowResponse</span> = serde_json::<span class="c-fn">from_slice</span>(&result_json)?;
println!(<span class="c-string">"temp: {}°C"</span>, resp.temp_c);</code></pre>
    </div>

    <div class="qs-footer">
      <%= link_to manage_actions_path, class: "btn-primary" do %>
        Explore actions <span>→</span>
      <% end %>
      <%= link_to actions_path, class: "btn-ghost" do %>
        Create an action
      <% end %>
    </div>
  </div>

</div>
