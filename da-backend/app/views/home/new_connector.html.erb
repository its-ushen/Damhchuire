<% content_for :title, "Create Connector — Damhchuire" %>

<div class="page-wrap"
     data-controller="connector-preview">

  <div class="page-hdr">
    <p class="page-hdr-tag">03 / Connectors</p>
    <h1 class="page-hdr-title">Create a connector.</h1>
    <p class="page-hdr-body">
      A connector wires a trigger to an on-chain action.
      Define one here and deploy it alongside your application.
    </p>
  </div>

  <div class="connector-body">
    <div class="connector-split">

      <%# ── Form ── %>
      <div class="connector-form-col">

        <div class="form-section">
          <span class="form-section-title">Identity</span>

          <div class="form-group">
            <label class="form-label" for="conn-name">Connector name</label>
            <input
              id="conn-name"
              type="text"
              class="form-input"
              placeholder="e.g. treasury-sweep"
              data-connector-preview-target="name"
              data-action="input->connector-preview#update"
            >
            <span class="form-hint">Lowercase, hyphens allowed. Used as the connector's identifier.</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="conn-network">Network</label>
            <select
              id="conn-network"
              class="form-select"
              data-connector-preview-target="network"
              data-action="change->connector-preview#update"
            >
              <option value="mainnet-beta">mainnet-beta</option>
              <option value="devnet" selected>devnet</option>
              <option value="testnet">testnet</option>
              <option value="localnet">localnet</option>
            </select>
          </div>
        </div>

        <div class="form-section">
          <span class="form-section-title">Trigger</span>

          <div class="form-group">
            <label class="form-label" for="conn-trigger">Trigger type</label>
            <select
              id="conn-trigger"
              class="form-select"
              data-connector-preview-target="trigger"
              data-action="change->connector-preview#update"
            >
              <option value="webhook">HTTP Webhook</option>
              <option value="on_chain_event">On-chain event</option>
              <option value="schedule">Schedule (cron)</option>
              <option value="manual">Manual</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="conn-trigger-val">Trigger value</label>
            <input
              id="conn-trigger-val"
              type="text"
              class="form-input"
              placeholder="e.g. 0 * * * *  or  https://api.example.com/hook"
              data-connector-preview-target="triggerValue"
              data-action="input->connector-preview#update"
            >
          </div>
        </div>

        <div class="form-section">
          <span class="form-section-title">Action</span>

          <div class="form-group">
            <label class="form-label" for="conn-action">Action</label>
            <select
              id="conn-action"
              class="form-select"
              data-connector-preview-target="action"
              data-action="change->connector-preview#update"
            >
              <optgroup label="Native">
                <option value="sol.transfer">sol.transfer</option>
              </optgroup>
              <optgroup label="Token">
                <option value="spl.transfer">spl.transfer</option>
              </optgroup>
              <optgroup label="Staking">
                <option value="sol.stake">sol.stake</option>
                <option value="sol.unstake">sol.unstake</option>
              </optgroup>
              <optgroup label="DeFi">
                <option value="dex.swap">dex.swap</option>
                <option value="defi.deposit">defi.deposit</option>
                <option value="defi.withdraw">defi.withdraw</option>
              </optgroup>
              <optgroup label="NFT">
                <option value="nft.mint">nft.mint</option>
                <option value="nft.transfer">nft.transfer</option>
              </optgroup>
              <optgroup label="Governance">
                <option value="gov.vote">gov.vote</option>
              </optgroup>
              <optgroup label="Security">
                <option value="multisig.approve">multisig.approve</option>
              </optgroup>
              <optgroup label="Advanced">
                <option value="program.cpi">program.cpi</option>
              </optgroup>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="conn-api-key">API key <span style="color:var(--text-subtle);font-weight:400;">(optional)</span></label>
            <input
              id="conn-api-key"
              type="password"
              class="form-input"
              placeholder="sk-..."
              data-connector-preview-target="apiKey"
              data-action="input->connector-preview#update"
            >
            <span class="form-hint">Stored encrypted. Injected as <code style="font-family:var(--font-mono);font-size:0.85em;">{{ credential.&lt;slug&gt;_api_key }}</code> in headers.</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="conn-payload">Payload template <span style="color:var(--text-subtle);font-weight:400;">(optional)</span></label>
            <textarea
              id="conn-payload"
              class="form-textarea"
              placeholder='{ "to": "{{recipient}}", "amount": "{{amount}}" }'
              data-connector-preview-target="payload"
              data-action="input->connector-preview#update"
            ></textarea>
            <span class="form-hint">Use <code style="font-family:var(--font-mono);font-size:0.85em;">{{variable}}</code> for dynamic values injected at runtime.</span>
          </div>
        </div>

        <button class="connector-submit" type="button">
          Deploy connector <span>→</span>
        </button>

      </div>

      <%# ── Live preview ── %>
      <div class="connector-preview-col">
        <p class="preview-label">Live preview</p>
        <div class="preview-window">
          <div class="code-window-bar">
            <span class="code-dot code-dot-r"></span>
            <span class="code-dot code-dot-y"></span>
            <span class="code-dot code-dot-g"></span>
            <span class="code-window-title">connector.json</span>
          </div>
          <pre class="preview-code" data-connector-preview-target="preview"></pre>
        </div>
      </div>

    </div>
  </div>

</div>
