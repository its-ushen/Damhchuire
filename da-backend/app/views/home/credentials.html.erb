<% content_for :title, "Credentials — Damhchuire" %>

<div class="page-wrap"
     data-controller="credential-form">

  <div class="page-hdr">
    <p class="page-hdr-tag">04 / Credentials</p>
    <h1 class="page-hdr-title">Manage credentials.</h1>
    <p class="page-hdr-body">
      Credentials are stored encrypted and injected into action headers at runtime.
      Reference them in any headers template as
      <code style="font-family:var(--font-mono);font-size:0.85em;background:var(--bg-subtle);padding:0.1em 0.4em;border-radius:3px;">{{credential.name}}</code>.
    </p>
  </div>

  <div class="connector-body">
    <div class="connector-split">

      <%# ── Form ── %>
      <div class="connector-form-col">

        <div class="form-section">
          <span class="form-section-title">New credential</span>

          <div class="form-group">
            <label class="form-label" for="cred-name">Name</label>
            <input
              id="cred-name"
              type="text"
              class="form-input"
              placeholder="e.g. my_api_key"
              data-credential-form-target="name"
            >
            <span class="form-hint">Alphanumeric and underscores only. Referenced as <code style="font-family:var(--font-mono);font-size:0.85em;">{{credential.my_api_key}}</code>.</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="cred-value">Value</label>
            <input
              id="cred-value"
              type="password"
              class="form-input"
              placeholder="sk-..."
              data-credential-form-target="value"
            >
            <span class="form-hint">Stored encrypted. Never exposed in API responses.</span>
          </div>
        </div>

        <button class="connector-submit" type="button"
          data-credential-form-target="submit"
          data-action="click->credential-form#create">
          Add credential <span>→</span>
        </button>

      </div>

      <%# ── Stored credentials list ── %>
      <div class="connector-preview-col">
        <p class="preview-label">Stored credentials</p>
        <div class="cred-list" data-credential-form-target="list">
          <p class="cred-empty">Loading…</p>
        </div>
      </div>

    </div>
  </div>

</div>
