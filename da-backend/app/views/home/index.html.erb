<% content_for :title, "Damhchuire — The action layer for Solana" %>

<section class="hero">
  <div class="hero-inner">

    <%# ── Left: copy ── %>
    <div class="hero-content">
      <span class="hero-tag">
        <span class="hero-tag-dot"></span>
        SDK · v0.1.0 · Solana
      </span>

      <h1 class="hero-heading">
        The action<br>
        layer for<br>
        <em>Solana.</em>
      </h1>

      <p class="hero-body">
        Emit, coordinate, and acknowledge on-chain actions
        from any environment. A lightweight SDK designed
        to get out of your way.
      </p>

      <div class="hero-actions">
        <%= link_to quickstart_path, class: "btn-primary" do %>
          Get started <span>→</span>
        <% end %>
        <%= link_to actions_library_path, class: "btn-ghost" do %>
          Browse actions
        <% end %>
      </div>
    </div>

    <%# ── Right: code window ── %>
    <div class="hero-code-wrap">
      <div class="code-window">
        <div class="code-window-bar">
          <span class="code-dot code-dot-r"></span>
          <span class="code-dot code-dot-y"></span>
          <span class="code-dot code-dot-g"></span>
          <span class="code-window-title">quickstart.rs</span>
        </div>
        <pre class="code-block"><code><span class="c-comment"># Cargo.toml</span>
damhchuire-sdk = <span class="c-string">{ path = "../da-sdk/rust" }</span>

<span class="c-keyword">use</span> damhchuire_sdk::{<span class="c-fn">call_weather_now_action_from</span>, <span class="c-fn">WeatherNowParams</span>};

<span class="c-keyword">let</span> request_id = <span class="c-fn">call_weather_now_action_from</span>(
    &<span class="c-keyword">mut</span> ctx.accounts.state,
    <span class="c-fn">WeatherNowParams</span> { city: <span class="c-string">"Dublin"</span>.to_string(), unit: <span class="c-fn">None</span> },
)?;

<span class="c-dim">// emits ActionRequested on-chain</span></code></pre>
      </div>
    </div>

  </div>
</section>
