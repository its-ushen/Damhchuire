<% content_for :title, "Chord — The action layer for Solana" %>

<section class="hero">
  <div class="hero-inner">

    <%# ── Left: copy ── %>
    <div class="hero-content">
      <span class="hero-tag">
        <span class="hero-tag-dot"></span>
        SDK · v0.1.0 · Solana
      </span>

      <h1 class="hero-heading">
        The action<br>
        layer for<br>
        <em>Solana.</em>
      </h1>

      <p class="hero-body">
        Emit, coordinate, and acknowledge on-chain actions
        from any environment. A lightweight SDK designed
        to get out of your way.
      </p>

      <div class="hero-actions">
        <%= link_to quickstart_path, class: "btn-primary" do %>
          Get started <span>→</span>
        <% end %>
        <%= link_to manage_actions_path, class: "btn-ghost" do %>
          Browse actions
        <% end %>
      </div>
    </div>

    <%# ── Right: code window ── %>
    <div class="hero-code-wrap">
      <div class="code-window">
        <div class="code-window-bar">
          <span class="code-dot code-dot-r"></span>
          <span class="code-dot code-dot-y"></span>
          <span class="code-dot code-dot-g"></span>
          <span class="code-window-title">quickstart.rs</span>
        </div>
        <pre class="code-block"><code><span class="c-comment">// send a slack message</span>
<span class="c-keyword">use</span> chord_sdk::*;

<span class="c-comment">// connect to slack</span>
<span class="c-fn">send_message_to_transactions_slack_channel</span>(
    <span class="c-string">"Received {} lamports!"</span>
    num_lamports_received
);

<span class="c-comment">// talk to an llm</span>
<span class="c-fn">openai_chat</span>(
    <span class="c-string">"gpt-4o"</span>.to_string(),
    <span class="c-string">"Summarise this transaction."</span>.to_string(),
);

<span class="c-comment">// grab weather data</span>
<span class="c-fn">get_current_weather</span>(
    <span class="c-string">"Dublin"</span>.to_string()
);</code></pre>
      </div>
    </div>

  </div>
</section>
