<% content_for :title, "Actions Library — Damhchuire" %>

<% tags = @actions.map { |a| a[:http_method] }.uniq.sort %>

<div class="page-wrap" data-controller="action-library">

  <div class="page-hdr">
    <p class="page-hdr-tag">02 / Actions Library</p>
    <h1 class="page-hdr-title">Library of actions.</h1>
    <p class="page-hdr-body">
      Every action is a first-class primitive — typed, versioned, and acknowledgment-capable.
      Emit them with a single <code style="font-family:var(--font-mono);font-size:0.85em;background:var(--bg-subtle);padding:0.1em 0.4em;border-radius:3px;">client.emit()</code> call.
    </p>
  </div>

  <div class="actions-body">

    <div class="actions-filter">
      <button class="filter-btn active" data-filter="all">All</button>
      <% tags.each do |tag| %>
        <button class="filter-btn" data-filter="<%= tag %>"><%= tag %></button>
      <% end %>
    </div>

    <div class="actions-grid" id="actions-grid">
      <% @actions.each do |action| %>
        <% logo = action[:slug].split("_").first %>
        <div class="action-card" data-tag="<%= action[:http_method] %>"
             data-action="click->action-library#openModal"
             data-action-slug="<%= action[:slug] %>"
             data-action-name="<%= action[:name] %>">
          <div class="action-card-header">
            <span class="action-card-tag"><%= action[:http_method] %></span>
            <span class="action-card-arrow">↗</span>
          </div>
          <div class="action-card-logo"><%= action_logo_svg(logo) %></div>
          <div class="action-card-name"><%= action[:name] %></div>
        </div>
      <% end %>
    </div>

  </div>

  <div class="modal-backdrop" data-action-library-target="backdrop"
       data-action="click->action-library#backdropClose">
    <div class="modal">
      <div class="modal-hdr">
        <span class="modal-title" data-action-library-target="title"></span>
        <button class="modal-close" data-action="click->action-library#closeModal">✕</button>
      </div>
      <div class="modal-body">
        <p class="form-hint">
          This action authenticates its HTTP request using a stored credential.
          Select which credential to inject wherever <code style="font-family:var(--font-mono);font-size:0.85em;background:var(--bg-subtle);padding:0.1em 0.4em;border-radius:3px;">{{credentials.name}}</code>
          appears in the action's headers template.
        </p>
        <div class="form-group">
          <label class="form-label" for="lib-cred-select">Credential</label>
          <select id="lib-cred-select" class="form-select"
                  data-action-library-target="credSelect"
                  data-action="change->action-library#credChange"></select>
        </div>
      </div>
      <div class="modal-footer">
        <button class="modal-cancel" data-action="click->action-library#closeModal">Cancel</button>
        <button class="modal-save" data-action-library-target="useBtn"
                data-action="click->action-library#use" disabled>Use credential</button>
      </div>
    </div>
  </div>

</div>

<script type="module">
  const buttons = document.querySelectorAll('.filter-btn')
  const cards   = document.querySelectorAll('.action-card')

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')

      const filter = btn.dataset.filter
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.tag === filter
        card.style.display = show ? '' : 'none'
      })
    })
  })
</script>
